// Fordania Verkstad – Prisma-schema
// Multi-tenant: tenant-data separeras på radnivå via organizationId.
// Auth-tabeller (User/Session/Account/Verification/Organization/Member/
// Invitation) hanteras av Better Auth.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  role          String?
  banned        Boolean?     @default(false)
  banReason     String?
  banExpires    DateTime?
  /** Senaste aktivitet (uppdateras via presence-heartbeat) – för "inne nu". */
  lastSeenAt    DateTime?
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]
  assignedJobs  Job[]        @relation("AssignedJobs")
  jobMechanics  JobMechanic[]

  @@unique([email])
  @@map("users")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?
  impersonatedBy       String?

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Organization {
  id          String       @id
  name        String
  slug        String
  logo        String?
  createdAt   DateTime     @default(now())
  metadata    String?
  // Fordania tenant-fält
  city        String?
  plan        String       @default("Bas")
  status      String       @default("active")
  // Fakturauppgifter – avsändare på arbetsorder/faktura (redigeras i Inställningar)
  orgNumber        String?
  vatNumber        String?
  address          String?
  postalCode       String?
  email            String?
  phone            String?
  bankgiro         String?
  paymentTermsDays Int     @default(30)
  members     Member[]
  invitations Invitation[]
  vehicles               Vehicle[]
  mechanics              Mechanic[]
  jobs                   Job[]
  customers              Customer[]
  vehicleFieldDefinitions VehicleFieldDefinition[]
  workOrderImages        WorkOrderImage[]

  @@unique([slug])
  @@map("organizations")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("members")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitations")
}

// ------------------------------------------------------------------ //
//  Tenant-scopad domändata – separeras på radnivå via organizationId
// ------------------------------------------------------------------ //

model Vehicle {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Statiska fält
  regNo          String
  chassisNumber  String?
  brand          String?
  model          String?
  year           Int?
  /// Mjukradering: satt = borttaget (döljs överallt men kan återställas).
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  jobs           Job[]
  // Dynamiska fält (definieras per tenant) och mätarställningshistorik
  fieldValues    VehicleFieldValue[]
  odometer       OdometerReading[]
  // Många-till-många: ett fordon kan kopplas till flera kunder
  customers      CustomerVehicle[]
  jobVehicles    JobVehicle[]
  imageLinks     WorkOrderImageVehicle[]

  @@index([organizationId])
  // Snabb filtrering av aktiva/borttagna fordon per verkstad (mjukradering).
  @@index([organizationId, deletedAt])
  @@map("vehicles")
}

/// Tenant-definierade dynamiska fält för fordon (t.ex. Märke, Färg, Årsmodell).
model VehicleFieldDefinition {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  label          String
  // text | number | date
  type           String              @default("text")
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  values         VehicleFieldValue[]

  @@index([organizationId])
  @@map("vehicle_field_definitions")
}

/// Värdet för ett dynamiskt fält på ett specifikt fordon.
model VehicleFieldValue {
  id           String                 @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  definitionId String
  definition   VehicleFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  value        String

  @@unique([vehicleId, definitionId])
  @@index([vehicleId])
  @@map("vehicle_field_values")
}

/// Historik av mätarställningar – varje uppdatering är en ny rad med datum.
model OdometerReading {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  value       Int
  readingDate DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([vehicleId])
  @@map("odometer_readings")
}

model Mechanic {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  initials       String
  role           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  jobs           Job[]

  @@index([organizationId])
  @@map("mechanics")
}

model Job {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicleId      String?
  vehicle        Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  mechanicId     String?
  mechanic       Mechanic?    @relation(fields: [mechanicId], references: [id], onDelete: SetNull)
  // Tilldelad mekaniker = inloggad användare (member). Används av arbetskalendern.
  assignedUserId String?
  assignedUser   User?        @relation("AssignedJobs", fields: [assignedUserId], references: [id], onDelete: SetNull)
  // Service, Reparation, Besiktning, Däckbyte, Rekond, Felsökning
  type           String
  // planned, in_progress, waiting_parts, done, delayed
  status         String
  start          String
  durationMin    Int
  // Riktig tidsplacering för kalendern (start/durationMin är legacy).
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  description    String?
  priority       String       @default("normal")
  /// Mjukradering: satt = borttagen (döljs överallt men kan återställas).
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  // Många-till-många: en arbetsorder kan ha flera mekaniker och flera fordon,
  // samt en lista med inköp/delar.
  mechanics      JobMechanic[]
  vehicles       JobVehicle[]
  parts          JobPart[]
  images         WorkOrderImage[]

  @@index([organizationId])
  @@index([assignedUserId])
  // Snabb filtrering av aktiva/borttagna arbetsordrar per verkstad (mjukradering).
  @@index([organizationId, deletedAt])
  @@map("jobs")
}

/// Kopplingstabell arbetsorder ↔ mekaniker (= användare). Bär även
/// arbetskostnaden: varje mekaniker har en egen timlön (exkl. moms, i öre)
/// och ett antal fakturerade timmar på ordern. Summan räknas i koden.
model JobMechanic {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Timlön exkl. moms i öre (per mekaniker på just den här ordern).
  hourlyRateOreExcl Int?
  /// Antal fakturerade timmar för mekanikern på ordern.
  hours             Float?
  /// Momssats för arbetskostnaden (arbete är normalt 25 %).
  vatRate           Int      @default(25)
  createdAt         DateTime @default(now())

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
  @@map("job_mechanics")
}

/// Kopplingstabell arbetsorder ↔ fordon.
model JobVehicle {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([jobId, vehicleId])
  @@index([jobId])
  @@index([vehicleId])
  @@map("job_vehicles")
}

/// Inköp/del på en arbetsorder. Pris lagras exkl. moms i öre (heltal) plus
/// momssats; inkl. moms och summor beräknas i koden.
model JobPart {
  id               String   @id @default(cuid())
  jobId            String
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title            String
  purchaseDate     DateTime @default(now())
  quantity         Int      @default(1)
  unitPriceExclOre Int
  vatRate          Int      @default(25)
  createdAt        DateTime @default(now())

  @@index([jobId])
  @@map("job_parts")
}

/// Bild uppladdad på en arbetsorder. Länkas till ett eller flera av orderns
/// fordon via WorkOrderImageVehicle. Kunden härleds via fordonen (som resten
/// av appen) så bilden dyker upp både på fordons- och kundprofilen.
model WorkOrderImage {
  id             String                  @id @default(cuid())
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobId          String
  job            Job                     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  // Nyckel i lagringsabstraktionen (src/lib/storage.ts) – filsystem nu, kan
  // bytas till volym/objektlagring senare utan schemaändring.
  storageKey     String
  fileName       String
  mimeType       String
  sizeBytes      Int
  caption        String?
  uploadedByName String?
  createdAt      DateTime                @default(now())
  vehicles       WorkOrderImageVehicle[]

  @@index([organizationId])
  @@index([jobId])
  @@map("work_order_images")
}

/// Kopplingstabell bild ↔ fordon: vilka av arbetsorderns fordon bilden avser.
model WorkOrderImageVehicle {
  id        String         @id @default(cuid())
  imageId   String
  image     WorkOrderImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  vehicleId String
  vehicle   Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([imageId, vehicleId])
  @@index([imageId])
  @@index([vehicleId])
  @@map("work_order_image_vehicles")
}

// ------------------------------------------------------------------ //
//  Kundregister – biluthyrningens kunder (tenant-scopat)
// ------------------------------------------------------------------ //

model Customer {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // "private" (privatperson) | "company" (företag). För företag är `name`
  // företagsnamnet och personnr ersätts av orgNumber + en primär kontaktperson.
  type           String            @default("private")
  name           String
  personalNumber String?
  // Organisationsnummer (endast företag), format "NNNNNNNN-NNNN".
  orgNumber      String?
  email          String?
  phone          String?
  address        String?
  /// Mjukradering: satt = borttagen (döljs överallt men kan återställas).
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  comments       CustomerComment[]
  // Kontaktpersoner: företagets primära kontaktperson (isPrimary) samt övriga
  // personer som får lämna/hämta fordon. Gäller både privat och företag.
  contacts       CustomerContact[]
  // Många-till-många: en kund kan ha flera fordon
  vehicles       CustomerVehicle[]

  @@index([organizationId])
  // Snabb filtrering av aktiva/borttagna kunder per verkstad (mjukradering).
  @@index([organizationId, deletedAt])
  @@map("customers")
}

/// Kontaktperson kopplad till en kund. För företagskunder är den med
/// `isPrimary = true` "kontaktpersonen" på företaget; övriga är personer som
/// får lämna eller hämta ut fordon.
model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  // Fri beskrivning, t.ex. "Kontaktperson", "Hämtar bil", "Verkstadsansvarig".
  role       String?
  phone      String?
  email      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@map("customer_contacts")
}

/// Kopplingstabell kund ↔ fordon (många-till-många).
model CustomerVehicle {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, vehicleId])
  @@index([customerId])
  @@index([vehicleId])
  @@map("customer_vehicles")
}

model CustomerComment {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  text       String
  authorName String?
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@map("customer_comments")
}

// ------------------------------------------------------------------ //
//  Systemlogg (audit trail) – vem gjorde vad, när och var. Läses av
//  superadmin. Aktör/företag denormaliseras (snapshot) så att raderna
//  består även om användare eller företag senare tas bort.
// ------------------------------------------------------------------ //

model AuditLog {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  // Aktör (snapshot – kontot kan tas bort senare)
  userId           String?
  userName         String
  userEmail        String?
  userRole         String?
  // Företagskontext (snapshot)
  organizationId   String?
  organizationName String?
  // Vad som hände
  action           String // t.ex. "job.create", "auth.login"
  category         String // "auth" | "job" | "vehicle" | "customer" | "user" | "tenant"
  entityType       String?
  entityId         String?
  summary          String // människoläsbar sammanfattning på svenska
  // Härkomst
  ipAddress        String?
  userAgent        String?

  @@index([createdAt])
  @@index([organizationId])
  @@index([userId])
  @@index([category])
  @@map("audit_logs")
}
